# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/pitchiq"

# Admin auth (min 32 chars)
ADMIN_SESSION_SECRET="your-random-secret-at-least-32-characters-long"

# Stripe: set here or in Admin → Settings (admin overrides env)
STRIPE_SECRET_KEY="sk_live_…"
STRIPE_WEBHOOK_SECRET="whsec_…"
# Optional: Stripe Price IDs for subscription plans (create in Stripe Dashboard)
# If not set, price_data is generated dynamically
STRIPE_PRO_PRICE_ID=""       # $29/mo recurring price
STRIPE_GROWTH_PRICE_ID=""    # $79/mo recurring price

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ANTHROPIC_API_KEY=""

# NextAuth (required for user sign-in)
NEXTAUTH_SECRET=""            # Generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"  # Set to https://pitchiq.vercel.app in production

# OAuth providers (at least one required for sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Thesys — generative UI for charts and visual content
THESYS_API_KEY=""
