generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deck {
  id            String   @id @default(uuid())
  shareId       String   @unique
  title         String
  companyName   String
  industry      String
  stage         String
  fundingTarget String
  investorType  String
  keyMetrics    String   @default("")
  teamInfo      String   @default("")
  problem       String   @default("")
  solution      String   @default("")
  slides        String   // JSON string of slide data
  isPremium     Boolean  @default(false)
  themeId       String   @default("midnight")
  piqScore      String   @default("{}") // JSON string of PIQScore
  source        String   @default("generated") // "generated" | "uploaded"
  originalFileName String? // original file name for uploaded decks

  // Location & market
  country         String?               // ISO 3166-1 alpha-2: "US", "GB", "NG", "IN"
  city            String?               // "San Francisco", "Lagos", "London"
  currency        String?  @default("USD") // ISO 4217: USD, EUR, GBP, NGN, INR
  targetMarkets   String?  @default("[]") // JSON: ["US", "Europe", "Global"]

  // Business model & traction
  businessModel      String?  // "saas" | "marketplace" | "hardware" | "services" | "consumer" | "deeptech" | "biotech" | "media"
  revenueModel       String?  // "subscription" | "transactional" | "advertising" | "licensing" | "freemium" | "usage-based" | "hybrid"
  customerType       String?  // "b2b" | "b2c" | "b2b2c" | "b2g" | "d2c"
  monthlyRevenue     Float?   // MRR in home currency
  annualRevenue      Float?   // ARR in home currency
  revenueGrowthRate  Float?   // Month-over-month % (e.g., 15.5 = 15.5%)
  userCount          Int?     // Total users/customers
  teamSize           Int?
  foundedYear        Int?

  // Fundraising specifics
  dealStructure      String?  // "equity" | "safe" | "convertible_note" | "revenue_based"
  preMoneyValuation  Float?   // In home currency
  previousRaised     Float?   // Total previously raised, home currency
  hasLeadInvestor    Boolean? @default(false)

  // Team characteristics
  founderCount         Int?
  hasRepeatFounder     Boolean? @default(false)
  hasTechnicalFounder  Boolean? @default(false)
  founderDiversity     String?  @default("[]") // JSON: ["gender-diverse", "ethnicity-diverse", "immigrant-founded"]

  // Smart Refine: content extraction & refinement lineage
  uploadedSlideTexts  String?          // JSON: string[] — raw text per slide from upload
  extractedContent    String?          // JSON: ExtractedDeckContent — AI-extracted structured data
  refinedFromId       String?          // ID of the deck this was refined from
  refinedFrom         Deck?    @relation("DeckRefinements", fields: [refinedFromId], references: [id])
  refinements         Deck[]   @relation("DeckRefinements")
  refinementNotes     String?          // JSON: improvements summary from refinement
  generationMeta      String?          // JSON: { dna, narrative, visualSystem } from generation pipeline

  userId        String?
  owner         User?    @relation("UserDecks", fields: [userId], references: [id])
  workspaceId   String?
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  views         View[]
  transactions  Transaction[]
  versions      DeckVersion[]
  parentVariants DeckVariant[] @relation("ParentDeck")
  asVariant     DeckVariant?  @relation("VariantDeck")
  alerts        DeckAlert[]
  comments      SlideComment[]
  practiceSessions PitchPracticeSession[]

  @@index([userId])
  @@index([workspaceId])
  @@index([refinedFromId])
}

model View {
  id          String   @id @default(uuid())
  deckId      String
  deck        Deck     @relation(fields: [deckId], references: [id])
  viewerIp    String   @default("")
  userAgent   String   @default("")
  slideViews  String   @default("[]") // JSON: [{slideIndex, timeSpent}]
  totalTime   Int      @default(0) // seconds
  createdAt   DateTime @default(now())

  @@index([deckId])
  @@index([createdAt])
}

// --- Admin & payments ---
enum Role {
  user
  admin
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  emailVerified        DateTime?
  passwordHash         String    @default("")
  name                 String?
  image                String?
  role                 Role      @default(user)
  plan                 String    @default("starter") // starter | pro | growth | enterprise
  suspended            Boolean   @default(false)
  suspendedAt          DateTime?
  suspendedReason      String?
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  planExpiresAt        DateTime?
  // Branding preferences (Pro+ plans)
  brandingEnabled      Boolean   @default(true) // show "Made with PitchIQ" — paid users can toggle off
  customLogoUrl        String?
  customCompanyName    String?
  customAccentColor    String?
  lastSeenAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  accounts             Account[]
  sessions             Session[]
  decks                Deck[]    @relation("UserDecks")
  transactions         Transaction[]
  ownedWorkspaces      Workspace[]       @relation("OwnedWorkspaces")
  workspaceMemberships WorkspaceMember[]
  comments             SlideComment[]
  activityLogs         ActivityLog[]
  abTests              ABTest[]
  investorContacts     InvestorContact[]
  apiKeys              ApiKey[]
  batchJobs            BatchJob[]
  customDomains        CustomDomain[]
  practiceSessions     PitchPracticeSession[]
  startupProfiles      StartupProfile[]
  // PAYG
  periodPasses         PeriodPass[]
  creditBalance        CreditBalance?
  creditTransactions   CreditTransaction[]
  generationJobs       GenerationJob[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Transaction {
  id               String   @id @default(uuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id])
  deckId           String?
  deck             Deck?    @relation(fields: [deckId], references: [id])
  stripePaymentId  String?  // Stripe payment intent or session id
  amountCents      Int
  currency         String   @default("usd")
  status           String   // pending | succeeded | failed | refunded
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([deckId])
  @@index([stripePaymentId])
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. stripe_secret_key, stripe_publishable_key
  value     String   // secret keys never returned to client; admin can overwrite
  updatedAt DateTime @updatedAt
}

// --- Plan configuration (admin-managed) ---
model PlanConfig {
  id              String   @id @default(uuid())
  planKey         String   @unique // "starter" | "pro" | "growth" | "enterprise"
  sortOrder       Int      @default(0)
  enabled         Boolean  @default(true)

  // Display metadata
  displayName     String
  description     String   @default("")
  price           String   // "$29" or "Free"
  priceUnit       String   @default("/mo")
  highlight       Boolean  @default(false)
  badge           String?  // "Popular", "Best Value", null
  ctaText         String   @default("Start Free Trial")
  ctaHref         String   @default("/create")
  features        String   @default("[]") // JSON string[] — bullet points on pricing cards

  // Stripe integration
  stripePriceId   String?
  stripeAmount    Int?     // amount in cents (2900 = $29)

  // Plan limits — mirrors PlanLimits interface
  // Use -1 for Infinity values
  maxDecks            Int     @default(1)
  allowedThemes       String  @default("[\"midnight\"]") // JSON string[]
  piqScoreDetail      String  @default("basic") // "basic" | "full"
  showBranding        Boolean @default(true)
  pdfWatermark        Boolean @default(true)
  pptxExport          Boolean @default(false)
  analytics           Boolean @default(false)
  investorVariants    Boolean @default(false)
  abTesting           Boolean @default(false)
  followUpAlerts      Boolean @default(false)
  investorCRM         Boolean @default(false)
  fundraiseTracker    Boolean @default(false)
  editor              Boolean @default(false)
  aiCoachingPerSlide  Boolean @default(false)
  investorLens        Boolean @default(false)
  pitchSimulator      Boolean @default(false)
  maxVersionHistory   Int     @default(0)
  smartBlocks         Boolean @default(false)
  deckTemplates       Boolean @default(false)
  appendixGenerator   Boolean @default(false)
  teamCollaboration   Boolean @default(false)
  maxWorkspaceMembers Int     @default(0)
  customDomain        Boolean @default(false)
  apiAccess           Boolean @default(false)
  batchScoring        Boolean @default(false)
  maxApiKeys          Int     @default(0)
  apiRateLimit        Int     @default(0)
  maxBatchSize        Int     @default(0)
  pitchPractice       Boolean @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- Version history for editor ---
model DeckVersion {
  id         String   @id @default(uuid())
  deckId     String
  deck       Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  version    Int
  slides     String   // JSON snapshot of slides at this version
  piqScore   String   @default("{}") // PIQ score at this version
  changeNote String?  // auto-generated or user-provided
  createdAt  DateTime @default(now())

  @@index([deckId, version])
}

// --- Deck variants for investor targeting ---
model DeckVariant {
  id            String   @id @default(uuid())
  parentDeckId  String
  parentDeck    Deck     @relation("ParentDeck", fields: [parentDeckId], references: [id], onDelete: Cascade)
  variantDeckId String   @unique
  variantDeck   Deck     @relation("VariantDeck", fields: [variantDeckId], references: [id], onDelete: Cascade)
  investorType  String   // vc | angel | accelerator
  createdAt     DateTime @default(now())
}

// --- A/B testing ---
model ABTest {
  id        String   @id @default(uuid())
  shareSlug String   @unique
  deckAId   String
  deckBId   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- Follow-up alerts ---
model DeckAlert {
  id        String   @id @default(uuid())
  deckId    String
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  type      String   // "high_engagement" | "new_view"
  viewId    String?
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([deckId])
}

// --- Team collaboration ---
model Workspace {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  ownerId     String
  owner       User     @relation("OwnedWorkspaces", fields: [ownerId], references: [id])
  brandConfig String   @default("{}") // JSON: { logoUrl, primaryColor, accentColor, companyName, hidePitchiqBranding }
  members       WorkspaceMember[]
  invites       WorkspaceInvite[]
  decks         Deck[]
  activities    ActivityLog[]
  customDomains CustomDomain[]
  createdAt     DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  role        String    // "owner" | "editor" | "viewer"
  joinedAt    DateTime  @default(now())

  @@unique([workspaceId, userId])
}

model WorkspaceInvite {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        String    @default("editor")
  token       String    @unique
  expiresAt   DateTime
  accepted    Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

// --- Slide comments ---
model SlideComment {
  id         String   @id @default(uuid())
  deckId     String
  deck       Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  slideIndex Int
  blockId    String?  // optional: comment on specific block
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  content    String
  resolved   Boolean  @default(false)
  parentId   String?  // thread replies
  parent     SlideComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies    SlideComment[] @relation("CommentReplies")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([deckId, slideIndex])
}

// --- Investor database (admin-managed, used for matching) ---
model InvestorProfile {
  id              String   @id @default(uuid())
  name            String                          // "Sequoia Capital" or "Naval Ravikant"
  type            String   @default("vc")         // vc | angel | accelerator | family_office | corporate
  website         String?
  logoUrl         String?
  description     String?                         // Short bio or investment thesis summary

  // Matching dimensions
  stages          String   @default("[]")         // JSON: ["pre-seed","seed","series-a","series-b"]
  sectors         String   @default("[]")         // JSON: ["fintech","saas","healthtech","ai","marketplace"]
  geographies     String   @default("[]")         // JSON: ["US","Europe","Global","Asia"]
  chequeMin       Float?                          // Minimum cheque in USD (e.g., 50000)
  chequeMax       Float?                          // Maximum cheque in USD (e.g., 2000000)
  thesis          String?                         // Free-text investment thesis

  // Granular location
  country         String?                         // ISO 3166-1 alpha-2: "US", "GB", "SG"
  city            String?                         // "Menlo Park", "London"
  currencies      String   @default("[]")         // JSON: ["USD", "EUR"]

  // Investment preferences
  businessModels    String   @default("[]")       // JSON: ["saas", "marketplace", "deeptech"]
  revenueModels     String   @default("[]")       // JSON: ["subscription", "transactional"]
  customerTypes     String   @default("[]")       // JSON: ["b2b", "b2c"]
  dealStructures    String   @default("[]")       // JSON: ["equity", "safe", "convertible_note"]
  valuationMin      Float?                        // Min pre-money they'll consider (USD)
  valuationMax      Float?                        // Max pre-money they'll consider (USD)

  // Traction thresholds
  minRevenue        Float?                        // Minimum MRR they look for (USD)
  minGrowthRate     Float?                        // Minimum MoM growth % they want
  minTeamSize       Int?

  // Fund characteristics
  fundVintage       Int?                          // Year current fund was raised
  fundSize          Float?                        // Total fund size in USD
  deploymentPace    String?                       // "active" | "moderate" | "slow" | "fully-deployed"
  averageCheckCount Int?                          // Deals per year
  leadPreference    String?                       // "lead-only" | "co-lead" | "follow" | "any"
  boardSeatRequired Boolean  @default(false)
  syndicateOpen     Boolean  @default(false)      // Open to syndication
  followOnReserve   Boolean  @default(true)       // Reserves capital for follow-on

  // Thesis & focus
  impactFocus       Boolean  @default(false)      // ESG/impact-focused
  diversityLens     Boolean  @default(false)      // Invests with diversity thesis
  thesisKeywords    String   @default("[]")       // JSON: ["API-first", "developer tools", "vertical SaaS"]

  // Portfolio intelligence
  portfolioCompanies       String   @default("[]") // JSON: full portfolio for conflict detection
  portfolioConflictSectors String   @default("[]") // JSON: sectors where they have competing bets

  // Activity & responsiveness
  lastActiveDate    DateTime?                     // Last known investment date
  avgResponseDays   Int?                          // Average days to first response
  avgCloseWeeks     Int?                          // Average weeks from first meeting to close
  declinedSectors   String   @default("[]")       // JSON: sectors they explicitly avoid

  // Network
  coInvestors       String   @default("[]")       // JSON: frequent co-investor names
  lpTypes           String   @default("[]")       // JSON: ["endowment", "pension", "sovereign-wealth", "corporate"]

  // Portfolio & credibility
  notableDeals    String   @default("[]")         // JSON: ["Stripe","Airbnb","Coinbase"]
  aum             String?                         // Assets under management (display text)
  partnerCount    Int?

  // Contact & source
  contactEmail    String?
  linkedIn        String?
  twitter         String?
  source          String   @default("seed")       // "seed" | "admin" | "api"

  // Admin controls
  verified        Boolean  @default(false)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  matchEvents     MatchEvent[]

  @@index([type])
  @@index([enabled])
}

// --- Fundraise tracker ---
model InvestorContact {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  firm           String?
  email          String?
  status         String    @default("identified") // identified | contacted | meeting | due_diligence | term_sheet | committed | passed
  notes          String    @default("")
  tags           String    @default("[]") // JSON string[] — e.g., ["Tier 1","Warm intro","Fintech focus"]
  nextFollowUp   DateTime?
  investorProfileId String? // optional link to InvestorProfile (when saved from matching)

  // Enhanced CRM fields
  warmIntro          Boolean?  @default(false)    // User has a warm intro path
  introSource        String?                      // "mutual connection", "portfolio founder", etc.
  sentimentScore     Int?                         // -2 to +2 based on latest interaction
  lastInteractionAt  DateTime?
  dealProbability    Int?                         // 0-100 user estimate
  expectedCloseDate  DateTime?
  termSheetReceived  Boolean?  @default(false)
  commitAmount       Float?                       // Amount committed if status = committed

  outreach       Outreach[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([userId, status])
}

model Outreach {
  id        String   @id @default(uuid())
  contactId String
  contact   InvestorContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String   // email | meeting | call | note
  content   String
  sentAt    DateTime @default(now())

  @@index([contactId])
}

// --- Activity log ---
model ActivityLog {
  id          String     @id @default(uuid())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  deckId      String?
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  action      String     // "deck.created" | "deck.edited" | "comment.added" | "member.invited" | etc.
  metadata    String     @default("{}") // JSON details
  createdAt   DateTime   @default(now())

  @@index([workspaceId, createdAt])
  @@index([deckId, createdAt])
  @@index([userId, createdAt])
}

// --- API keys ---
model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String    @default("Default")
  keyHash    String    @unique
  keyPrefix  String    // first 8 chars for display: "piq_abc1..."
  scopes     String    @default("[]") // JSON array: ["decks:read","decks:write","score","batch"]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([keyHash])
}

// --- Batch scoring ---
model BatchJob {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String   @default("Untitled Batch")
  status     String   @default("pending") // pending | processing | completed | failed
  totalDecks Int      @default(0)
  completed  Int      @default(0)
  failed     Int      @default(0)
  results    String   @default("[]") // JSON: [{ fileName, shareId?, score, grade, error? }]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
}

// --- Custom domains ---
model CustomDomain {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId       String?
  workspace         Workspace? @relation(fields: [workspaceId], references: [id])
  domain            String    @unique
  status            String    @default("pending") // pending | verifying | active | failed
  verificationToken String    @unique
  verifiedAt        DateTime?
  sslStatus         String    @default("pending") // pending | active
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([domain])
}

// --- Pitch practice sessions ---
model PitchPracticeSession {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deckId       String
  deck         Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  duration     Int      @default(0) // total seconds
  slideTimings String   @default("[]") // JSON: [{slideIndex, duration, transcript?}]
  aiFeedback   String   @default("{}") // JSON: { overall, pacing, clarity, confidence, suggestions[] }
  status       String   @default("in_progress") // in_progress | completed | abandoned
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([deckId])
  @@index([userId, deckId])
}

// --- Startup profile (founder company info for matching) ---
model StartupProfile {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core identity
  companyName        String
  tagline            String?
  country            String                         // ISO 3166-1 alpha-2
  city               String?
  currency           String   @default("USD")       // ISO 4217

  // Classification
  industry           String                         // Primary industry
  sectors            String   @default("[]")        // JSON: normalized sector tags
  businessModel      String?                        // saas | marketplace | hardware | etc.
  revenueModel       String?                        // subscription | transactional | etc.
  customerType       String?                        // b2b | b2c | b2b2c | b2g

  // Stage & traction
  stage              String                         // pre-seed | seed | series-a | etc.
  monthlyRevenue     Float?                         // MRR in home currency
  annualRevenue      Float?                         // ARR in home currency
  revenueGrowthRate  Float?                         // MoM %
  userCount          Int?
  teamSize           Int?
  foundedYear        Int?

  // Fundraising
  fundingTarget      Float?                         // Amount seeking, home currency
  dealStructure      String?                        // equity | safe | convertible_note
  preMoneyValuation  Float?
  previousRaised     Float?
  hasLeadInvestor    Boolean  @default(false)
  targetMarkets      String   @default("[]")        // JSON: ["US", "Europe"]

  // Team
  founderCount         Int?
  hasRepeatFounder     Boolean  @default(false)
  hasTechnicalFounder  Boolean  @default(false)
  founderDiversity     String   @default("[]")      // JSON

  // Preferences
  investorTypePrefs    String   @default("[]")      // JSON: ["vc", "angel"]
  leadNeeded           Boolean  @default(true)
  boardSeatOk          Boolean  @default(true)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

// --- Match event analytics ---
model MatchEvent {
  id                 String   @id @default(uuid())
  userId             String
  investorProfileId  String
  investorProfile    InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  deckId             String?
  fitScore           Int                            // Score at time of match
  action             String                         // "viewed" | "saved" | "dismissed" | "contacted"
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([investorProfileId])
  @@index([createdAt])
}

// --- Notifications ---
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String                                  // "new_matches" | "follow_up_due" | "pipeline_stale"
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  String   @default("{}")                 // JSON
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// --- Period Pass: time-bound access at a tier level ---
model PeriodPass {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier            String   // "basic" | "growth" | "full"
  startsAt        DateTime
  expiresAt       DateTime
  durationDays    Int      // 1, 3, 7, 14, 30, etc.

  // Stripe
  stripePaymentId String?
  amountCents     Int      // What they paid
  currency        String   @default("usd")

  // Status
  status          String   @default("active") // "active" | "expired" | "refunded"
  autoRenew       Boolean  @default(false)

  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([userId, status])
  @@index([expiresAt])
}

// --- Credit balance ---
model CreditBalance {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)  // Current credit balance
  lifetime  Int      @default(0)  // Total credits ever purchased (for loyalty/stats)
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// --- Credit transactions (full audit trail) ---
model CreditTransaction {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         String   // "purchase" | "usage" | "refund" | "bonus" | "expiry"
  amount       Int      // Positive for additions, negative for usage
  balanceAfter Int      // Balance after this transaction (for audit trail)

  // For purchases
  packId            String?
  stripePaymentId   String?
  amountCents       Int?     // What they paid in cents

  // For usage
  action       String?  // "create_deck" | "ai_generation" | "export_pptx" | etc.
  resourceId   String?  // ID of the deck/resource the credit was spent on

  description  String?  // Human-readable: "Created deck 'Series A Pitch'"
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([userId, type])
  @@index([createdAt])
}

// --- Admin-configurable PAYG pricing ---
model PaygConfig {
  id        String   @id @default(uuid())
  key       String   @unique  // Config key
  value     String             // JSON value
  updatedAt DateTime @updatedAt
}

// --- Matching algorithm config (admin-tunable) ---
model MatchingConfig {
  id              String   @id @default(uuid())
  name            String   @unique @default("default")
  weights         String   @default("{}")           // JSON: dimension → weight
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- Generation Jobs (skill pipeline tracking) ---
model GenerationJob {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  deckId          String?
  status          String    @default("pending") // pending | running | completed | failed
  input           String    // JSON: DeckInput
  progress        Int       @default(0) // 0-100
  currentPhase    String?
  skillResults    String?   // JSON: skill outputs
  critiqueResults String?   // JSON: critique outputs
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([status])
}
