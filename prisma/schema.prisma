generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deck {
  id            String   @id @default(uuid())
  shareId       String   @unique
  title         String
  companyName   String
  industry      String
  stage         String
  fundingTarget String
  investorType  String
  keyMetrics    String   @default("")
  teamInfo      String   @default("")
  problem       String   @default("")
  solution      String   @default("")
  slides        String   // JSON string of slide data
  isPremium     Boolean  @default(false)
  themeId       String   @default("midnight")
  piqScore      String   @default("{}") // JSON string of PIQScore
  userId        String?
  owner         User?    @relation("UserDecks", fields: [userId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  views         View[]
  transactions  Transaction[]
}

model View {
  id          String   @id @default(uuid())
  deckId      String
  deck        Deck     @relation(fields: [deckId], references: [id])
  viewerIp    String   @default("")
  userAgent   String   @default("")
  slideViews  String   @default("[]") // JSON: [{slideIndex, timeSpent}]
  totalTime   Int      @default(0) // seconds
  createdAt   DateTime @default(now())
}

// --- Admin & payments (UPH-53) ---
enum Role {
  user
  admin
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String    @default("")
  name          String?
  image         String?
  role          Role      @default(user)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  decks         Deck[]    @relation("UserDecks")
  transactions  Transaction[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Transaction {
  id               String   @id @default(uuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id])
  deckId           String?
  deck             Deck?    @relation(fields: [deckId], references: [id])
  stripePaymentId  String?  // Stripe payment intent or session id
  amountCents      Int
  currency         String   @default("usd")
  status           String   // pending | succeeded | failed | refunded
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([deckId])
  @@index([stripePaymentId])
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. stripe_secret_key, stripe_publishable_key
  value     String   // secret keys never returned to client; admin can overwrite
  updatedAt DateTime @updatedAt
}
